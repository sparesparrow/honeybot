# SCAIPOT Configuration
#
# ⚠️  SECURITY WARNINGS:
# 1. NEVER commit this file with real secrets to version control
# 2. Generate strong random secrets for production (see examples below)
# 3. Change ALL default passwords before deploying to production
# 4. Set ENV=production to enable security validation

# Platform API Keys
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SIGNAL_PHONE_NUMBER=+420123456789
SIGNAL_SERVICE=signal-cli-rest-api:8080
SIGNAL_STORAGE_PATH=/var/lib/scaipot/signal

# Claude API
# Required for production deployment
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# MCP-Prompts Server
MCP_PROMPTS_URL=http://mcp-prompts:3003
MCP_PROMPTS_API_KEY=optional_api_key_if_enabled

# Database
# ⚠️  SECURITY: Change 'password' to a strong password for production!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(16))"
DATABASE_URL=postgresql://scaipot:password@postgres:5432/scaipot
DATABASE_POOL_SIZE=20

# Redis
# ⚠️  SECURITY: Set a strong Redis password for production!
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your_redis_password

# Admin & Alerting
ADMIN_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ADMIN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
ADMIN_EMAIL=admin@sparesparrow.dev

# Honeypot Configuration
# VM spawning requires docker-socket-proxy for security
HONEYPOT_VM_ENABLED=false
HONEYPOT_NETWORK_ANALYSIS_ENABLED=false
# Use tcp://docker-proxy:2375 when VM spawning is enabled
DOCKER_HOST=tcp://docker-proxy:2375

# Security
# ⚠️  CRITICAL: Generate a strong random secret for JWT tokens!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This MUST be changed for production - application will refuse to start otherwise
JWT_SECRET=change-this-in-production
ALLOWED_ORIGINS=http://localhost:3001,https://admin.sparesparrow.dev

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text
SENTRY_DSN=

# Environment
# Set to "production" to enable security validation
ENV=development  # or staging, production
DEBUG=true
