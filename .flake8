[flake8]
# Match Black's line length
max-line-length = 100

# Exclude common directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist,
    htmlcov

# TODO: Re-enable these checks after code cleanup
# F401: imported but unused
# F841: local variable assigned but never used
ignore = F401,F841
