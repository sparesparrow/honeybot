"""SCAIPOT Application Entry Point"""

import asyncio
import logging
from typing import Dict, List, Optional
from dataclasses import dataclass

from scaipot.bots.telegram_bot import TelegramHoneypot
from scaipot.bots.signal_bot import SignalHoneypot
from scaipot.mcp_integration.mcp_client import MCPPromptsClient
from scaipot.llm_engine.claude_client import ClaudeClient
from scaipot.storage.db import Database
from scaipot.config.config import SCaipotConfig

logger = logging.getLogger(__name__)


@dataclass
class SCAIPOT:
    """Main SCAIPOT application orchestrator"""
    
    config: SCaipotConfig
    db: Database
    mcp_client: MCPPromptsClient
    llm_engine: ClaudeClient
    telegram_bot: Optional[TelegramHoneypot] = None
    signal_bot: Optional[SignalHoneypot] = None
    
    async def initialize(self) -> None:
        """Initialize SCAIPOT application"""
        logger.info("Initializing SCAIPOT v0.1.0...")
        
        # Connect to database
        await self.db.connect()
        logger.info("✓ Database connected")
        
        # Load categories from MCP-Prompts
        categories = await self.mcp_client.get_all_categories()
        logger.info(f"✓ Loaded {len(categories)} honeypot categories from MCP-Prompts")
        
        # Initialize bots based on config
        if self.config.telegram_enabled:
            self.telegram_bot = TelegramHoneypot(
                token=self.config.telegram_bot_token,
                mcp_client=self.mcp_client,
                llm_engine=self.llm_engine,
                db=self.db
            )
            logger.info("✓ Telegram honeypot initialized")
        
        if self.config.signal_enabled:
            self.signal_bot = SignalHoneypot(
                phone_number=self.config.signal_phone_number,
                mcp_client=self.mcp_client,
                llm_engine=self.llm_engine,
                db=self.db
            )
            logger.info("✓ Signal honeypot initialized")
    
    async def start(self) -> None:
        """Start all honeypots"""
        logger.info("Starting honeypots...")
        
        tasks = []
        if self.telegram_bot:
            tasks.append(self.telegram_bot.start())
        if self.signal_bot:
            tasks.append(self.signal_bot.start())
        
        await asyncio.gather(*tasks)
    
    async def shutdown(self) -> None:
        """Gracefully shutdown SCAIPOT"""
        logger.info("Shutting down SCAIPOT...")
        await self.db.disconnect()
        logger.info("✓ SCAIPOT shutdown complete")
