"""Telegram Honeypot Implementation"""

import logging
from telegram import Update
from telegram.ext import Application, MessageHandler, filters, ContextTypes

from scaipot.bots.base import BaseHoneypot

logger = logging.getLogger(__name__)


class TelegramHoneypot(BaseHoneypot):
    """Telegram-specific honeypot bot"""
    
    def __init__(self, token: str, **kwargs):
        super().__init__(**kwargs)
        self.token = token
        self.app: Optional[Application] = None
    
    async def start(self) -> None:
        """Start Telegram honeypot"""
        logger.info("Starting Telegram honeypot...")
        
        self.app = Application.builder().token(self.token).build()
        
        # Register message handler
        self.app.add_handler(
            MessageHandler(
                filters.TEXT & ~filters.COMMAND,
                self._handle_telegram_message
            )
        )
        
        # Start polling
        await self.app.run_polling()
    
    async def _handle_telegram_message(
        self,
        update: Update,
        context: ContextTypes.DEFAULT_TYPE
    ) -> None:
        """Handle Telegram message"""
        sender_id = str(update.effective_user.id)
        message = update.message.text
        group_id = update.effective_chat.title if update.effective_chat else None
        
        # Generate response
        response = await self.handle_message(
            sender_id=sender_id,
            message=message,
            platform="telegram",
            group_id=group_id
        )
        
        if response:
            await update.message.reply_text(response)
