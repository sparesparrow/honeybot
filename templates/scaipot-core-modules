```python
"""Fraud Pattern Detection"""

import logging
import re
import hashlib
from typing import Dict, Any

logger = logging.getLogger(__name__)


class PatternDetector:
    """Detect fraud indicators in scammer messages"""
    
    def __init__(self):
        self.urgency_keywords = [
            "hurry", "limited time", "act now", "ending soon",
            "rychle", "ihned", "dnes", "okamžitě"
        ]
        
        self.btc_pattern = r'\\b[13][a-km-zA-HJ-NP-Z1-9]{25,34}\\b|bc1[a-z0-9]{39,59}\\b'
        self.eth_pattern = r'0x[a-fA-F0-9]{40}'
        self.url_pattern = r'https?://[^\\s]+'
    
    def detect_pattern(self, message: str) -> Dict[str, Any]:
        """Detect fraud patterns in message"""
        
        indicators = {
            "is_fraud": False,
            "patterns": [],
            "btc_addresses": [],
            "eth_addresses": [],
            "urls": [],
            "urgency": False,
            "pattern_hash": self._compute_pattern_hash(message)
        }
        
        # Check urgency
        if any(kw in message.lower() for kw in self.urgency_keywords):
            indicators["urgency"] = True
            indicators["patterns"].append("urgency_detected")
        
        # Extract cryptocurrency addresses
        btc_matches = re.findall(self.btc_pattern, message)
        if btc_matches:
            indicators["btc_addresses"] = btc_matches
            indicators["patterns"].append("btc_address_present")
        
        eth_matches = re.findall(self.eth_pattern, message)
        if eth_matches:
            indicators["eth_addresses"] = eth_matches
            indicators["patterns"].append("eth_address_present")
        
        # Extract URLs
        url_matches = re.findall(self.url_pattern, message)
        if url_matches:
            indicators["urls"] = url_matches
            indicators["patterns"].append("url_present")
        
        # Determine if fraud
        indicators["is_fraud"] = len(indicators["patterns"]) > 0
        
        logger.debug(f"Pattern detection result: {indicators}")
        return indicators
    
    def _compute_pattern_hash(self, message: str) -> str:
        """Create semantic hash for caching similar messages"""
        normalized = re.sub(r'\\d+', 'NUM', message)
        normalized = re.sub(r'\\b[A-Z][a-z]+\\b', 'NAME', normalized)
        return hashlib.md5(normalized.encode()).hexdigest()[:16]
