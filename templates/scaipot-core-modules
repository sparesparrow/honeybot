"""Base Bot Implementation"""

import logging
from abc import ABC, abstractmethod
from typing import Dict, Any, Optional
from datetime import datetime

from scaipot.mcp_integration.mcp_client import MCPPromptsClient
from scaipot.llm_engine.claude_client import ClaudeClient
from scaipot.fraud_detection.pattern_detector import PatternDetector
from scaipot.storage.db import Database

logger = logging.getLogger(__name__)


class BaseHoneypot(ABC):
    """Abstract base class for honeypot bots"""
    
    def __init__(
        self,
        mcp_client: MCPPromptsClient,
        llm_engine: ClaudeClient,
        db: Database,
        default_category: str = "general"
    ):
        self.mcp_client = mcp_client
        self.llm_engine = llm_engine
        self.db = db
        self.pattern_detector = PatternDetector()
        self.default_category = default_category
        self.conversations: Dict[str, list] = {}
    
    @abstractmethod
    async def start(self) -> None:
        """Start honeypot listening for messages"""
        pass
    
    async def handle_message(
        self,
        sender_id: str,
        message: str,
        platform: str,
        group_id: Optional[str] = None
    ) -> Optional[str]:
        """Handle incoming message from scammer"""
        logger.info(f"[{platform}] Message from {sender_id}: {message[:100]}")
        
        # Initialize conversation if new
        if sender_id not in self.conversations:
            self.conversations[sender_id] = []
        
        # Detect fraud patterns
        fraud_indicators = self.pattern_detector.detect_pattern(message)
        if fraud_indicators.get("is_fraud"):
            logger.warning(f"Fraud detected from {sender_id}: {fraud_indicators}")
            await self._alert_admin(sender_id, message, fraud_indicators, platform)
        
        # Get honeypot category (from group name or config)
        category = self._detect_category(group_id or self.default_category)
        
        # Fetch category prompts from MCP-Prompts
        category_config = await self.mcp_client.get_category_prompt(
            category=category,
            platform=platform
        )
        
        # Generate response using Claude (with caching)
        response = await self.llm_engine.generate_response(
            system_prompt=category_config["system_prompt"],
            scammer_message=message,
            conversation_history=self.conversations[sender_id],
            category=category
        )
        
        # Store conversation
        self.conversations[sender_id].append({
            "role": "user",
            "content": message,
            "timestamp": datetime.now().isoformat()
        })
        self.conversations[sender_id].append({
            "role": "assistant",
            "content": response,
            "timestamp": datetime.now().isoformat()
        })
        
        # Log to database
        await self.db.log_conversation(
            sender_id=sender_id,
            platform=platform,
            category=category,
            message=message,
            response=response,
            fraud_indicators=fraud_indicators
        )
        
        return response
    
    def _detect_category(self, group_name: str) -> str:
        """Detect scam category from group name using keywords"""
        keywords_map = {
            "bitcoin": ["bitcoin", "btc", "crypto", "blockchain"],
            "defi": ["defi", "yield", "liquidity", "uniswap", "pancakeswap"],
            "investment": ["investment", "trading", "forex", "stock"],
            "romance": ["dating", "singles", "relationship", "love"],
            "job": ["job", "work", "employment", "remote"],
        }
        
        for category, keywords in keywords_map.items():
            if any(kw in group_name.lower() for kw in keywords):
                return category
        
        return self.default_category
    
    async def _alert_admin(
        self,
        sender_id: str,
        message: str,
        fraud_indicators: Dict[str, Any],
        platform: str
    ) -> None:
        """Send alert to admin about suspicious activity"""
        alert_text = (
            f"🚨 Potential Scammer Detected!\n\n"
            f"Platform: {platform}\n"
            f"Sender ID: {sender_id}\n"
            f"Message: {message[:200]}...\n"
            f"Indicators: {fraud_indicators}\n"
            f"Time: {datetime.now().isoformat()}"
        )
        
        await self.db.create_alert(
            sender_id=sender_id,
            platform=platform,
            alert_type="fraud_detected",
            message=alert_text,
            severity="high"
        )
