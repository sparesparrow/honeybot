"""MCP-Prompts Client"""

import logging
import httpx
import asyncio
from typing import Dict, Any, List
from functools import lru_cache

logger = logging.getLogger(__name__)


class MCPPromptsClient:
    """Client for MCP-Prompts server"""
    
    def __init__(self, base_url: str, api_key: str, cache_ttl: int = 300):
        self.base_url = base_url
        self.api_key = api_key
        self.cache_ttl = cache_ttl
        self.http_client = httpx.AsyncClient(
            base_url=base_url,
            headers={"Authorization": f"Bearer {api_key}"}
        )
    
    async def get_category_prompt(
        self,
        category: str,
        platform: str
    ) -> Dict[str, Any]:
        """Get category prompt configuration from MCP-Prompts"""
        try:
            response = await self.http_client.get(
                f"/v1/prompts/honeypot/category/{category}",
                params={"platform": platform}
            )
            response.raise_for_status()
            return response.json()
        except httpx.HTTPError as e:
            logger.error(f"Error fetching category prompt: {e}")
            raise
    
    async def get_all_categories(self) -> List[Dict[str, Any]]:
        """Get all available honeypot categories"""
        try:
            response = await self.http_client.get(
                "/v1/prompts/honeypot/categories"
            )
            response.raise_for_status()
            return response.json()
        except httpx.HTTPError as e:
            logger.error(f"Error fetching categories: {e}")
            raise
    
    async def close(self) -> None:
        """Close HTTP client"""
        await self.http_client.aclose()
