    console.print(f"✓ Signal Enabled: {config.signal_enabled}")
    
    console.print("[bold green]✓ SCAIPOT initialized successfully![/bold green]")


@cli.command()
def start():
    """Start SCAIPOT honeypots"""
    console.print("[bold green]Starting SCAIPOT honeypots...[/bold green]")
    
    config = SCaipotConfig()
    
