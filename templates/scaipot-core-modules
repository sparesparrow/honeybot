"""Command-Line Interface"""

import asyncio
import logging
import click
from click_rich.decorator import pass_info
from rich.console import Console

from scaipot.main import SCAIPOT
from scaipot.config.config import SCaipotConfig
from scaipot.storage.db import Database
from scaipot.mcp_integration.mcp_client import MCPPromptsClient
from scaipot.llm_engine.claude_client import ClaudeClient

logger = logging.getLogger(__name__)
console = Console()


@click.group()
@click.version_option()
def cli():
    """SCAIPOT - AI-Powered Cryptocurrency Scammer Honeypot"""
    logging.basicConfig(level=logging.INFO)


@cli.command()
def init():
    """Initialize SCAIPOT configuration"""
    console.print("[bold green]Initializing SCAIPOT...[/bold green]")
    
    config = SCaipotConfig()
    
    console.print(f"✓ Database URL: {config.database_url}")
    console.print(f"✓ MCP-Prompts URL: {config.mcp_prompts_url}")
