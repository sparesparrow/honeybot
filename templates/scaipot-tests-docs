import pytest
from unittest.mock import AsyncMock, patch
from scaipot.mcp_integration.mcp_client import MCPPromptsClient


@pytest.mark.asyncio
async def test_get_category_prompt():
    """Test fetching category prompt from MCP-Prompts"""
    
    client = MCPPromptsClient(
        base_url="http://localhost:3000",
        api_key="test_key"
    )
    
    with patch.object(client.http_client, 'get') as mock_get:
        mock_response = AsyncMock()
        mock_response.json.return_value = {
            "category": "bitcoin_investment",
            "system_prompt": "You are a curious investor...",
            "response_templates": {"initial": "Hi there!"}
        }
        mock_get.return_value = mock_response
        
        result = await client.get_category_prompt("bitcoin_investment", "telegram")
        
        assert result["category"] == "bitcoin_investment"
        assert "system_prompt" in result
        mock_get.assert_called_once()


@pytest.mark.asyncio
