import pytest
from unittest.mock import AsyncMock, patch, MagicMock
from scaipot.llm_engine.claude_client import ClaudeClient


@pytest.mark.asyncio
async def test_generate_response():
    """Test response generation with Claude"""
    
    client = ClaudeClient(api_key="test_key")
    
    with patch.object(client.client, 'messages') as mock_messages:
        # Mock Claude API response
        mock_response = MagicMock()
        mock_response.content = [MagicMock(text="That sounds interesting!")]
        mock_response.usage.cache_read_input_tokens = 100
        mock_messages.create.return_value = mock_response
        
        response = await client.generate_response(
            system_prompt="You are a curious investor",
            scammer_message="Send me 0.5 BTC",
            conversation_history=[],
            category="bitcoin_investment"
        )
        
        assert response == "That sounds interesting!"
        mock_messages.create.assert_called_once()


@pytest.mark.asyncio
async def test_prompt_caching():
    """Test that system prompt is cached"""
    
    client = ClaudeClient(api_key="test_key")
    
    with patch.object(client.client, 'messages') as mock_messages:
        mock_response = MagicMock()
        mock_response.content = [MagicMock(text="Response")]
        mock_response.usage.cache_read_input_tokens = 50  # Cache hit
        mock_messages.create.return_value = mock_response
        
        await client.generate_response(
            system_prompt="System prompt",
            scammer_message="Message",
            conversation_history=[],
            category="test"
        )
        
        # Verify that cache_control was set
        call_args = mock_messages.create.call_args
        assert call_args is not None
        # Check that ephemeral cache control is set on system prompt
