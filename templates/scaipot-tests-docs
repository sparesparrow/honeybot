## tests/unit/test_pattern_detector.py
```python
import pytest
from scaipot.fraud_detection.pattern_detector import PatternDetector


@pytest.fixture
def detector():
    return PatternDetector()


def test_detect_urgency_keywords(detector):
    """Test urgency keyword detection"""
    message = "Hurry! This opportunity is ending soon!"
    result = detector.detect_pattern(message)
    
    assert result["urgency"] is True
    assert "urgency_detected" in result["patterns"]
    assert result["is_fraud"] is True


def test_detect_btc_address(detector):
    """Test Bitcoin address detection"""
    message = "Send 0.5 BTC to 1A1z7agoat7SFy2o3a8sh9DZydtsuW5Ty"
    result = detector.detect_pattern(message)
    
    assert len(result["btc_addresses"]) > 0
    assert "btc_address_present" in result["patterns"]


def test_detect_url(detector):
    """Test URL detection"""
    message = "Click here to verify: https://fake-exchange.com/login"
    result = detector.detect_pattern(message)
    
    assert len(result["urls"]) > 0
    assert "https://fake-exchange.com/login" in result["urls"]


def test_pattern_hash_generation(detector):
    """Test pattern hash generation for caching"""
    message1 = "Send 0.5 BTC to 1A1z7agoat7SFy2o3a8sh9DZydtsuW5Ty"
    message2 = "Send 1.2 ETH to 1B2z7agoat7SFy2o3a8sh9DZydtsuW5Tz"
    
    result1 = detector.detect_pattern(message1)
    result2 = detector.detect_pattern(message2)
    
    # Different amounts should produce different hashes (due to NUM normalization)
    assert result1["pattern_hash"] is not None
    assert result2["pattern_hash"] is not None
```

